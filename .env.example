# Copy to .env locally. On Railway, set the same names under Service → Variables.
#
# UI-only tests with no API/helpers: npm run test:light (skips this file’s checks).
# Do not set PW_SKIP_ENV_CHECK on Railway when running API/integration tests.
# Use SELLD_* only if you already use that typo; SELDO_* is preferred.

# CRM/API origin for Playwright APIRequestContext (no trailing slash), e.g. https://yourcompany.sell.do
# Alternatively set only the tenant slug (expands to https://{slug}.sell.do):
# SELDO_SUBDOMAIN=
# On Railway only: if unset, check-env defaults to https://v2.sell.do (override for your tenant).
SELLDO_API_BASE_URL=

SELLDO_PASSWORD=
SELLDO_ADMIN_EMAIL=
SELLDO_CLIENT_ID=
SELLDO_FULL_ACCESS_API=
SELLDO_RESTRICTED_ACCESS_API=
