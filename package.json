    "@types/node": "^25.6.0",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "luxon": "^3.5.0",
    "xlsx": "^0.18.5"
  }
}
